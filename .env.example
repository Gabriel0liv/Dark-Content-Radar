YOUTUBE_API_KEY=coloca_tua_chave_aqui
AI_PROVIDER=ollama
AI_ANALYSIS_BATCH_SIZE=5
CONTENT_PROFILE=curiosity_ai_trends
DISCOVERY_MODE=hybrid
DISCOVERY_REGIONS=BR,US
DISCOVERY_LANGUAGES=pt,en,es
DISCOVERY_DAYS_BACK=30
TRENDING_DAYS_BACK=7
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_ANALYSIS_LIMIT=20
VIRAL_ONLY=true
VIRAL_ACCEPTANCE_MODE=or
MIN_TOTAL_VIEWS=1000000
MIN_VIEWS_PER_DAY=100000
MIN_RISING_TOTAL_VIEWS=300000
MIN_RISING_VIEWS_PER_DAY=50000
MIN_OPPORTUNITY_SCORE=70
VIRAL_STRICT_MODE=false
DAYS_BACK=7
REGION_CODE=BR
MAX_SEARCH_PAGES_PER_KEYWORD=2
MAX_RESULTS_PER_KEYWORD=50
YOUTUBE_POPULAR_REGIONS=BR,US
YOUTUBE_POPULAR_CATEGORIES=28,27,24,22
DATABASE_PATH=data/database.sqlite
OLLAMA_MODE=cloud_direct
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b
# Ollama Cloud direto:
# OLLAMA_MODE=cloud_direct
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL=gpt-oss:120b
# OLLAMA_API_KEY=sua_chave
#
# Ollama Cloud via daemon local:
# OLLAMA_MODE=cloud_daemon
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:120b-cloud
#
# Ollama local:
# OLLAMA_MODE=local
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen:latest
#
# CONTENT_PROFILE define o perfil editorial usado pela IA.
# Valores aceitos:
# general
# curiosity_ai_trends
# finance
# history_mystery
# psychology_behavior
#
# VIRAL_ONLY=true aceita apenas vídeos com total de views e views/dia altos.
# VIRAL_ACCEPTANCE_MODE=or aceita vídeos se baterem total views OU views/dia.
# VIRAL_ACCEPTANCE_MODE=and exige total views E views/dia, mais rígido.
# Para descobrir vídeos vencedores, use or.
# Para encontrar apenas explosões recentes, use and.
# MIN_TOTAL_VIEWS=1000000 exige pelo menos 1 milhão de views totais.
# MIN_VIEWS_PER_DAY=100000 exige pelo menos 100 mil views por dia.
# Se quiser mais resultados, usar:
# MIN_TOTAL_VIEWS=500000
# MIN_VIEWS_PER_DAY=50000
# MAX_SEARCH_PAGES_PER_KEYWORD controla quantas páginas da YouTube API buscar por keyword.
# 2 páginas x 50 resultados = até 100 vídeos brutos por keyword.
#
# DISCOVERY_MODE controla as fontes de descoberta:
# niche_keywords, broad_viral, youtube_popular ou hybrid.
# DISCOVERY_REGIONS e DISCOVERY_LANGUAGES sao usados em broad_viral.
# DISCOVERY_DAYS_BACK amplia a janela de coleta sem mudar o calculo de views/dia.
# YOUTUBE_POPULAR_CATEGORIES usa IDs da YouTube API; 28 tech, 27 educacao, 24 entretenimento, 22 pessoas/blogs.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
